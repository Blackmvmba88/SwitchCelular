{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peripheralos.dev/schemas/plugin-manifest.schema.json",
  "title": "PeripheralOS Plugin Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "abi",
    "capabilities",
    "permissions",
    "actions"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "abi": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "transports": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "lifecycle_hooks": {
      "type": "array",
      "items": {
        "enum": [
          "discover",
          "validate",
          "load",
          "configure",
          "start",
          "execute",
          "observe",
          "stop",
          "unload"
        ]
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
